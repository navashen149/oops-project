#include <iostream>
using namespace std;

class Student {
public:
    int roll;
    string name;

    void getData() {
        cout << "Enter Roll Number: ";
        cin >> roll;
        cout << "Enter Name: ";
        cin >> name;
    }

    void display() {
        cout << "Roll Number: " << roll << endl;
        cout << "Name: " << name << endl;
    }
};

int main() {
    Student s;          // object
    Student *ptr;       // object pointer

    ptr = &s;           // pointer stores address of object

    ptr->getData();     // accessing function using pointer
    ptr->display();

    return 0;
}
