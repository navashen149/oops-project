#include <iostream>
using namespace std;

class Base {
public:
    virtual void show() {
        cout << "This is Base class show function" << endl;
    }
};

class Derived : public Base {
public:
    void show() {
        cout << "This is Derived class show function" << endl;
    }
};

int main() {
    Base *b;
    Derived d;

    b = &d;      // base pointer pointing to derived object
    b->show();   // calls derived class function

    return 0;
}
